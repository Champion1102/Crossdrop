# CrossDrop Frontend Environment Variables
# Copy this file to .env or .env.local and update the values

# ===========================================
# API URL - Your hosted backend server URL
# ===========================================
#
# Examples:
#   - Development (local):     http://localhost:8000
#   - Production (hosted):     https://api.crossdrop.yourdomain.com
#
VITE_API_URL=

# ===========================================
# Signaling Server URL - WebRTC signaling server
# ===========================================
#
# Used for browser-to-browser file transfers via WebRTC
# Examples:
#   - Development (local):     http://localhost:3001
#   - Production (hosted):     https://crossdrop-backend-node.onrender.com
#
VITE_SIGNALING_URL=http://localhost:3001

# ===========================================
# TURN Servers - Required for NAT traversal
# ===========================================
#
# Without TURN servers, WebRTC connections fail when users are behind
# symmetric NATs (most home networks). STUN alone is not enough.
#
# Free option: Sign up at https://www.metered.ca/stun-turn (500GB/month free)
#   1. Create an account
#   2. Go to TURN Server → API Key
#   3. Copy your credentials below
#
# VITE_TURN_URLS accepts comma-separated TURN server URLs:
#
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Enable debug mode (set to false in production)
VITE_ENABLE_DEBUG=false
